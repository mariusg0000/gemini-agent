#!/usr/bin/env bash
# Launcher for the agentic Gemini CLI profile.
#
# Responsibilities:
#   1. Reroute user-level config to ~/.gemini-agent/ so the default
#      `gemini` profile is not touched.
#   2. Force a dedicated system prompt via GEMINI_SYSTEM_MD.
#   3. Default approval mode to `yolo` so ordinary tool calls run
#      without a UI prompt. The policy engine
#      (~/.gemini-agent/.gemini/policies/safety.toml) is the safety net
#      for destructive or privileged shell commands.
#   4. Disable sandboxing. YOLO auto-enables the sandbox by default,
#      which would block the agent and its subagents from real system
#      access. This profile is explicitly full-access; safety is
#      provided by the policy engine, not by a sandbox.
#   5. Activate the workspace Python venv so `python3`, `pip`, and
#      anything else the agent shells out to resolve to the workspace
#      interpreter, not the system Python. Without this, skills and
#      tool calls that use bare `python3` (e.g. project-hub capture)
#      depend on whatever Python is first on the caller's PATH, which
#      is non-deterministic and lets `pip install` pollute the system.
#   6. Avoid $HOME as the working directory. If Gemini is launched from
#      $HOME it picks up ~/.gemini/ (the default coding profile) as the
#      workspace tier and bleeds its skills/settings into the session.
#      When that happens, switch to the agent's dedicated workspace.
set -euo pipefail

export GEMINI_CLI_HOME="${HOME}/.gemini-agent"
export GEMINI_SYSTEM_MD="${HOME}/.gemini-agent/system.md"
: "${GEMINI_SANDBOX:=false}"
export GEMINI_SANDBOX

VENV="${HOME}/gemini-agent-workspace/venv"
if [ -d "$VENV" ]; then
  export VIRTUAL_ENV="$VENV"
  PATH="$VENV/bin:${PATH-}"
  export PATH
  unset PYTHONHOME
fi

if [ "$PWD" = "$HOME" ]; then
  WS="${HOME}/gemini-agent-workspace"
  mkdir -p "$WS"
  cd "$WS"
fi

# Ensure the current folder is treated as the workspace so internal tools
# like ReadFolder/ReadFile work natively on absolute paths relative to CWD.
CURRENT_WS=$(pwd)

# If the user did not already specify an approval mode, default to yolo.
want_default_approval=1
want_workspace_flag=1
for arg in "$@"; do
  case "$arg" in
    --yolo|--approval-mode|--approval-mode=*)
      want_default_approval=0
      ;;
    --workspace|--workspace=*)
      want_workspace_flag=0
      ;;
  esac
done

if [ "$want_workspace_flag" -eq 1 ]; then
  set -- --workspace="$CURRENT_WS" "$@"
fi

if [ "$want_default_approval" -eq 1 ]; then
  set -- --approval-mode=yolo "$@"
fi

exec gemini "$@"
